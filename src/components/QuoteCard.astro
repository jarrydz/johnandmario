---
import type { CollectionEntry } from 'astro:content';

interface Props {
  quote: CollectionEntry<'quotes'>;
}

const { quote } = Astro.props;
const { attribution, source } = quote.data;
const body = (quote.body ?? '').replace(/\s+/g, ' ').trim();
const byline = attribution ?? source ?? '';
---

<li class="quote-card">
  <blockquote class="quote-card-body">{body}</blockquote>
  {byline && <p class="quote-card-author">{byline}</p>}
</li>
