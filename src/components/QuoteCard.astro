---
import type { CollectionEntry } from 'astro:content';
import { withBase, quoteSlug } from '../utils';

interface Props {
  quote: CollectionEntry<'quotes'>;
}

const { quote } = Astro.props;
const { attribution, source, mood } = quote.data;
const href = withBase(`/read/${quoteSlug(quote.id)}`);

// Build a short preview from the markdown body — first paragraph, hard-capped.
const rawBody = (quote.body ?? '').replace(/\s+/g, ' ').trim();
const PREVIEW_MAX = 200;
const preview =
  rawBody.length > PREVIEW_MAX
    ? rawBody.slice(0, PREVIEW_MAX).replace(/\s+\S*$/, '') + '…'
    : rawBody;

const byline = attribution ?? source ?? '';
---

<li>
  <a href={href} class="quote-card" data-mood={mood}>
    <p class="quote-card-body">{preview}</p>
    <div class="quote-card-meta">
      {byline && <span class="quote-card-author">{byline}</span>}
      <span class="quote-card-mood">{mood}</span>
    </div>
  </a>
</li>
