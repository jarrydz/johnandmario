---
import { GITHUB_REPO } from '../consts';
import { withBase } from '../utils';

interface Props {
  minimal?: boolean;
}

const { minimal = false } = Astro.props;
---

{
  minimal ? (
    <footer class="site-footer site-footer-minimal">
      <a href={withBase('/about')}>About</a>
    </footer>
  ) : (
    <footer class="site-footer">
      <a href={withBase('/rss.xml')}>RSS</a>
      <a href={withBase('/search')}>Search</a>
      <a href={withBase('/archive')}>Archive</a>
      <a href={GITHUB_REPO} rel="noopener noreferrer">
        GitHub
      </a>
      <a href={withBase('/about')}>About</a>
    </footer>
  )
}
