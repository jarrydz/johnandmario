---
import { Image } from 'astro:assets';
import { render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import { withBase, formatDate } from '../utils';

interface Props {
  post: CollectionEntry<'posts'>;
}

const { post } = Astro.props;
const { Content } = await render(post);
const href = withBase(`/posts/${post.id}`);
const { title, image, image_alt, date, tags } = post.data;
---

<article class="post-card">
  {
    image && (
      <figure>
        <a href={href}>
          <Image
            src={image}
            alt={image_alt ?? ''}
            widths={[480, 720, 1080]}
            sizes="(max-width: 720px) 100vw, 720px"
            loading="lazy"
          />
        </a>
      </figure>
    )
  }
  {title && <h2 class="post-title"><a href={href}>{title}</a></h2>}
  <div class="caption"><Content /></div>
  <div class="post-meta">
    <a href={href}><time datetime={date.toISOString()}>{formatDate(date)}</time></a>
    {
      tags && tags.length > 0 && (
        <span class="tags">
          {tags.map((t) => (
            <span class="tag">#{t}</span>
          ))}
        </span>
      )
    }
  </div>
</article>
