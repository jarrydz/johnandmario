---
import { SITE_TITLE } from '../consts';
import { withBase } from '../utils';

interface Props {
  minimal?: boolean;
}

const { minimal = false } = Astro.props;
---

<header class="site-header" data-minimal={minimal ? '' : undefined}>
  <p class="site-title"><a href={withBase('/')}>{SITE_TITLE}</a></p>
  {
    !minimal && (
      <nav>
        <a href={withBase('/look')}>Look</a> · <a href={withBase('/read')}>Read</a> ·{' '}
        <a href={withBase('/about')}>About</a>
      </nav>
    )
  }
</header>
