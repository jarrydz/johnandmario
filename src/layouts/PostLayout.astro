---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import Attribution from '../components/Attribution.astro';
import { formatDate } from '../utils';

interface Props {
  post: CollectionEntry<'posts'>;
}

const { post } = Astro.props;
const { title, image, image_alt, date, tags, tumblr_url, source, source_url } =
  post.data;
---

<article class="post-single">
  {
    image && (
      <figure>
        <Image
          src={image}
          alt={image_alt ?? ''}
          widths={[480, 720, 1080]}
          sizes="(max-width: 720px) 100vw, 720px"
        />
      </figure>
    )
  }
  {title && <h1 class="post-title">{title}</h1>}
  <div class="caption prose"><slot /></div>

  <footer class="post-footer">
    <p><time datetime={date.toISOString()}>{formatDate(date)}</time></p>
    {
      tags && tags.length > 0 && (
        <p class="tags">
          {tags.map((t) => (
            <span class="tag">#{t}</span>
          ))}
        </p>
      )
    }
    <Attribution source={source} sourceUrl={source_url} />
    {
      tumblr_url && (
        <p>
          <a href={tumblr_url} rel="noopener noreferrer">
            Original Tumblr post
          </a>
        </p>
      )
    }
  </footer>
</article>
