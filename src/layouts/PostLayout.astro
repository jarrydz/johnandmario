---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import Attribution from '../components/Attribution.astro';
import RemoteImage from '../components/RemoteImage.astro';
import Tags from '../components/Tags.astro';
import { formatDate } from '../utils';

interface Props {
  post: CollectionEntry<'posts'>;
}

const { post } = Astro.props;
const {
  title,
  image,
  r2_key,
  image_width,
  image_height,
  image_alt,
  date,
  tags,
  description,
  tumblr_url,
  source,
  source_url,
} = post.data;
---

<article class="post-single">
  {
    (r2_key || image) && (
      <figure>
        {r2_key ? (
          <RemoteImage
            src={r2_key}
            alt={image_alt ?? ''}
            width={image_width}
            height={image_height}
            sizes="(max-width: 720px) 100vw, 720px"
            loading="eager"
          />
        ) : (
          <Image
            src={image}
            alt={image_alt ?? ''}
            widths={[480, 720, 1080]}
            sizes="(max-width: 720px) 100vw, 720px"
          />
        )}
      </figure>
    )
  }
  {title && <h1 class="post-title">{title}</h1>}
  <div class="caption prose">
    <slot />
    {description && <p class="post-description">{description}</p>}
  </div>

  <footer class="post-footer">
    <p><time datetime={date.toISOString()}>{formatDate(date)}</time></p>
    {tags && tags.length > 0 && <p class="tags-line"><Tags tags={tags} id={post.id} /></p>}
    <Attribution source={source} sourceUrl={source_url} />
    {
      tumblr_url && (
        <p>
          <a href={tumblr_url} rel="noopener noreferrer">
            Original Tumblr post
          </a>
        </p>
      )
    }
  </footer>
</article>
