---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import Attribution from '../components/Attribution.astro';
import RemoteImage from '../components/RemoteImage.astro';
import Tags from '../components/Tags.astro';
import { formatDate, withBase } from '../utils';

interface Props {
  post: CollectionEntry<'posts'>;
}

const { post } = Astro.props;
const {
  title,
  image,
  r2_key,
  image_width,
  image_height,
  image_alt,
  date,
  tags,
  description,
  tumblr_url,
  source,
  source_url,
} = post.data;
---

<article class="post-single">
  {
    (r2_key || image) && (
      <figure>
        {r2_key ? (
          <RemoteImage
            src={r2_key}
            alt={image_alt ?? ''}
            width={image_width}
            height={image_height}
            sizes="(max-width: 720px) 100vw, 720px"
            loading="eager"
          />
        ) : (
          <Image
            src={image}
            alt={image_alt ?? ''}
            widths={[480, 720, 1080]}
            sizes="(max-width: 720px) 100vw, 720px"
            data-pagefind-meta="image[src]"
          />
        )}
      </figure>
    )
  }
  {title && <h1 class="post-title">{title}</h1>}
  <div class="caption prose" data-pagefind-body>
    <slot />
    {description && <p class="post-description">{description}</p>}
  </div>

  <footer class="post-footer">
    <p><time datetime={date.toISOString()} data-pagefind-meta="date">{formatDate(date)}</time></p>
    {tags && tags.length > 0 && <p class="tags-line"><Tags tags={tags} id={post.id} /></p>}
    <Attribution source={source} sourceUrl={source_url} />
    {
      tumblr_url && (
        <p>
          <a href={tumblr_url} rel="noopener noreferrer">
            Original Tumblr post
          </a>
        </p>
      )
    }
  </footer>
</article>

<a href={withBase('/look')} class="post-back">Back</a>

<style>
  /* Bottom-left return link to the Look feed, mirroring the header/theme-toggle
     chrome (same font, weight, size, and edge padding). */
  .post-back {
    position: fixed;
    z-index: 100;
    bottom: 0;
    left: 0;
    padding: clamp(1.1rem, 3vw, 1.8rem) var(--pad-x);
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 0.95rem;
    letter-spacing: 0.01em;
    line-height: 1;
    color: var(--fg, var(--color-text));
    text-decoration: none;
    transition: opacity 0.2s ease;
  }
  .post-back:hover {
    opacity: 0.6;
  }
</style>
