---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  /** Portal-style chrome: wordmark only, no nav, no width-constrained container. */
  minimal?: boolean;
  /** Optional data-mood attribute on <body> for mood-preset CSS variable scoping. */
  mood?: string;
}

const { title, description, minimal = false, mood } = Astro.props;
---

<!doctype html>
<html lang="en-GB">
  <head>
    <BaseHead title={title} description={description} />
  </head>
  <body data-mood={mood}>
    <Header minimal={minimal} />
    {minimal ? <slot /> : <div class="container"><slot /></div>}
    <Footer minimal={minimal} />
  </body>
</html>
