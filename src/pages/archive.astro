---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import { withBase } from '../utils';

// A grid of every post as a thumbnail — Tumblr's /archive style.
const posts = (await getCollection('posts')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
---

<BaseLayout title="Archive" description="Every post, as a grid of thumbnails.">
  <h1>Archive</h1>
  <p class="post-meta">{posts.length} {posts.length === 1 ? 'post' : 'posts'}</p>

  <div class="archive-grid">
    {
      posts.map((post) => (
        <a
          class="thumb"
          href={withBase(`/posts/${post.id}`)}
          title={post.data.title ?? post.data.image_alt ?? ''}
        >
          {post.data.image ? (
            <Image src={post.data.image} alt={post.data.image_alt ?? ''} width={320} loading="lazy" />
          ) : (
            <span class="thumb-text">{post.data.title ?? post.data.post_type}</span>
          )}
        </a>
      ))
    }
  </div>
</BaseLayout>
