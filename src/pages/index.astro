---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { withBase } from '../utils';
import { IMAGE_CDN_BASE } from '../consts';

// A pool of random photo keys baked at build time; the client reshuffles and
// picks 20 on each load so the intro reel varies between visits.
const candidates = (await getCollection('posts'))
  .filter((p) => p.data.r2_key)
  .sort(() => Math.random() - 0.5)
  .slice(0, 80)
  .map((p) => p.data.r2_key as string);
---

<BaseLayout
  description="A personal archive. Photographs and quotes — two ways to read."
  minimal
>
  <main class="portal">
    <nav class="portal-nav">
      <a href={withBase('/look')} class="portal-link" data-tag="Photographs">Look</a>
      <a href={withBase('/read')} class="portal-link" data-tag="Quotes">Read</a>
      <a href={withBase('/words')} class="portal-link" data-tag="Writing">Words</a>
    </nav>
    <div class="intro-reel" id="intro-reel" aria-hidden="true">
      <img class="intro-reel-img" alt="" decoding="async" />
    </div>
  </main>
</BaseLayout>

<script define:vars={{ candidates, cdnBase: IMAGE_CDN_BASE }}>
  (function () {
    const reel = document.getElementById('intro-reel');
    const nav = document.querySelector('.portal-nav');
    if (!reel) return;
    const img = reel.querySelector('img');
    const reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;

    // No JS-driven intro: leave the words visible and drop the reel.
    if (reduce || !img || !candidates || candidates.length === 0) {
      reel.remove();
      return;
    }

    // Hide the words while the images play; reveal them once the reel ends.
    if (nav) nav.dataset.intro = 'hidden';

    const enc = (k) => k.split('/').map(encodeURIComponent).join('/');
    const url = (k) => `${cdnBase}/${enc(k)}?w=640&f=webp&q=80`;

    // Fisher–Yates shuffle, then take 20.
    const pool = candidates.slice();
    for (let i = pool.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [pool[i], pool[j]] = [pool[j], pool[i]];
    }
    const picks = pool.slice(0, 20).map(url);
    picks.forEach((u) => {
      const pre = new Image();
      pre.src = u;
    });

    const FRAME = 150;
    let i = 0;
    reel.classList.add('is-active');

    function finish() {
      // Last image has landed — fade the reel and write the words up.
      reel.classList.add('is-done');
      if (nav) nav.dataset.intro = 'in';
      setTimeout(() => reel.remove(), 600);
    }

    function tick() {
      img.src = picks[i];
      img.animate(
        [
          { transform: 'translateY(45%)', opacity: 0 },
          { transform: 'translateY(0)', opacity: 1 },
        ],
        { duration: FRAME, easing: 'ease-out' },
      );
      i++;
      if (i < picks.length) {
        setTimeout(tick, FRAME);
      } else {
        setTimeout(finish, 280);
      }
    }
    tick();
  })();
</script>

<style>
  .portal {
    position: fixed;
    inset: 0;
    padding: var(--pad-x);
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
  }
  .portal-nav {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: clamp(0.1rem, 1vh, 0.6rem);
    max-width: 100%;
  }
  .portal-link {
    position: relative;
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(3.5rem, 15vw, 9.6rem);
    line-height: 0.95;
    max-width: 100%;
    letter-spacing: -0.035em;
    text-transform: uppercase;
    color: var(--color-text);
    text-decoration: none;
    transition: opacity 0.2s ease;
  }
  /* Small serif annotations offset to alternating sides, like an editorial layout. */
  .portal-link::after {
    content: attr(data-tag);
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    font-family: var(--font-serif);
    font-weight: 400;
    font-size: clamp(0.7rem, 1.1vw, 0.95rem);
    letter-spacing: 0.02em;
    text-transform: none;
    white-space: nowrap;
    color: var(--color-muted);
    pointer-events: none;
  }
  .portal-link:nth-child(odd)::after {
    left: calc(100% + clamp(0.75rem, 2vw, 1.75rem));
  }
  .portal-link:nth-child(even)::after {
    right: calc(100% + clamp(0.75rem, 2vw, 1.75rem));
  }
  .portal-link:hover {
    font-family: 'Didot', 'Hoefler Text', 'Playfair Display', Georgia, serif;
    font-weight: 500;
    font-style: italic;
    text-transform: none;
    opacity: 1;
    color: var(--color-text);
  }

  /* Words start hidden while the image reel plays, then "write up" into place
     once the last image lands (data-intro is driven by the script). */
  .portal-nav[data-intro='hidden'] .portal-link {
    opacity: 0;
    transform: translateY(0.7em);
  }
  .portal-nav[data-intro='in'] .portal-link {
    opacity: 1;
    transform: translateY(0);
    transition:
      opacity 0.55s ease,
      transform 0.65s cubic-bezier(0.2, 0.75, 0.2, 1);
  }
  .portal-nav[data-intro='in'] .portal-link:nth-child(1) {
    transition-delay: 0s;
  }
  .portal-nav[data-intro='in'] .portal-link:nth-child(2) {
    transition-delay: 0.12s;
  }
  .portal-nav[data-intro='in'] .portal-link:nth-child(3) {
    transition-delay: 0.24s;
  }
  /* On phones the serif side-labels crowd the big type and overflow the
     viewport, so drop them and let the words carry the page on their own. */
  @media (max-width: 640px) {
    .portal-link::after {
      display: none;
    }
  }

  /* Intro reel — flicks through 20 random photos in the centre on load. */
  .intro-reel {
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    z-index: 60;
    width: clamp(208px, 26vw, 300px);
    aspect-ratio: 5 / 6;
    overflow: hidden;
    border-radius: 2px;
    pointer-events: none;
    opacity: 0;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.35);
  }
  .intro-reel.is-active {
    opacity: 1;
  }
  .intro-reel.is-done {
    opacity: 0;
    transition: opacity 0.45s ease;
  }
  .intro-reel-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
</style>
