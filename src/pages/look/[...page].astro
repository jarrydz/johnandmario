---
import { getCollection } from 'astro:content';
import type { GetStaticPaths } from 'astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { POSTS_PER_PAGE, SITE_DESCRIPTION } from '../../consts';

// Paginated, reverse-chronological photo feed at /look, /look/2, /look/3, …
// Moved from `/` to `/look` when Read mode joined the site (see ADR 0002).
export const getStaticPaths = (async ({ paginate }) => {
  const posts = (await getCollection('posts')).sort(
    (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
  );
  return paginate(posts, { pageSize: POSTS_PER_PAGE });
}) satisfies GetStaticPaths;

const { page } = Astro.props;
---

<BaseLayout title="Look" description={SITE_DESCRIPTION}>
  <main>
    {page.data.map((post) => <PostCard post={post} />)}

    <nav class="pagination">
      {page.url.prev ? <a href={page.url.prev}>← Newer</a> : <span class="spacer"></span>}
      <span>Page {page.currentPage} of {page.lastPage}</span>
      {page.url.next ? <a href={page.url.next}>Older →</a> : <span class="spacer"></span>}
    </nav>
  </main>
</BaseLayout>
