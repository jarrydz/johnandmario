---
import { getCollection } from 'astro:content';
import type { GetStaticPaths } from 'astro';
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import RemoteImage from '../../components/RemoteImage.astro';
import { withBase } from '../../utils';
import { POSTS_PER_PAGE, SITE_DESCRIPTION } from '../../consts';

// Paginated, reverse-chronological photo feed at /look, /look/2, /look/3, …
// Moved from `/` to `/look` when Read mode joined the site (see ADR 0002).
export const getStaticPaths = (async ({ paginate }) => {
  const posts = (await getCollection('posts')).sort(
    (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
  );
  return paginate(posts, { pageSize: POSTS_PER_PAGE });
}) satisfies GetStaticPaths;

const { page } = Astro.props;
---

<BaseLayout title="Look" description={SITE_DESCRIPTION}>
  <main>
    <div class="look-grid" id="look-grid" data-cols="3">
      {
        page.data.map((post) => {
          const { r2_key, image, image_width, image_height, image_alt } = post.data;
          if (!r2_key && !image) return null;
          return (
            <a href={withBase(`/posts/${post.id}`)} class="look-item">
              {r2_key ? (
                <RemoteImage
                  src={r2_key}
                  alt={image_alt ?? ''}
                  width={image_width}
                  height={image_height}
                  sizes="(max-width: 720px) 100vw, 720px"
                  loading="lazy"
                />
              ) : (
                <Image
                  src={image}
                  alt={image_alt ?? ''}
                  widths={[320, 480, 720]}
                  sizes="(max-width: 720px) 100vw, 720px"
                  loading="lazy"
                />
              )}
            </a>
          );
        })
      }
    </div>

    <nav class="pagination">
      {page.url.prev ? <a href={page.url.prev}>← Newer</a> : <span class="spacer"></span>}
      <span>Page {page.currentPage} of {page.lastPage}</span>
      {page.url.next ? <a href={page.url.next}>Older →</a> : <span class="spacer"></span>}
    </nav>
  </main>

  <div class="look-zoom" role="group" aria-label="Grid size">
    <button type="button" data-cols="1" aria-label="Single column">1</button>
    <button type="button" data-cols="3" aria-label="Three per row">3</button>
    <button type="button" data-cols="5" aria-label="Five per row">5</button>
    <button type="button" data-cols="7" aria-label="Seven per row">7</button>
  </div>
</BaseLayout>

<script>
  (function () {
    const grid = document.getElementById('look-grid');
    const zoom = document.querySelector('.look-zoom');
    if (!grid || !zoom) return;
    const KEY = 'look-cols';
    const allowed = ['1', '3', '5', '7'];

    const apply = (cols) => {
      grid.dataset.cols = cols;
      zoom.querySelectorAll('button').forEach((b) => {
        b.setAttribute('aria-pressed', String(b.dataset.cols === cols));
      });
      try {
        localStorage.setItem(KEY, cols);
      } catch (e) {}
    };

    let initial = grid.dataset.cols || '3';
    try {
      const saved = localStorage.getItem(KEY);
      if (saved && allowed.includes(saved)) initial = saved;
    } catch (e) {}
    apply(initial);

    zoom.addEventListener('click', (e) => {
      const btn = e.target.closest('button[data-cols]');
      if (btn) apply(btn.dataset.cols);
    });
  })();
</script>

<style>
  /* Look feed — a masonry grid whose column count is driven by the zoom
     control (bottom-right). CSS columns keep every photo at its natural aspect
     ratio and pack them without ragged rows. */
  .look-grid {
    --look-gap: 8px;
    column-gap: var(--look-gap);
  }
  .look-grid[data-cols='1'] {
    column-count: 1;
  }
  .look-grid[data-cols='3'] {
    column-count: 3;
  }
  .look-grid[data-cols='5'] {
    column-count: 5;
  }
  .look-grid[data-cols='7'] {
    column-count: 7;
  }
  .look-item {
    display: block;
    margin: 0 0 var(--look-gap);
    break-inside: avoid;
    line-height: 0;
  }
  .look-item :global(img),
  .look-item :global(picture) {
    display: block;
    width: 100%;
    height: auto;
  }

  /* Zoom control — bottom-left, mirroring the header/theme-toggle chrome
     (same font, weight, size, and edge padding). Look page only. */
  .look-zoom {
    position: fixed;
    z-index: 100;
    bottom: 0;
    left: 0;
    display: flex;
    align-items: baseline;
    gap: 0.7rem;
    padding: clamp(1.1rem, 3vw, 1.8rem) var(--pad-x);
  }
  .look-zoom button {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 0.95rem;
    letter-spacing: 0.01em;
    line-height: 1;
    color: var(--color-muted);
    background: none;
    border: 0;
    padding: 0;
    cursor: inherit;
    transition: opacity 0.2s ease;
  }
  .look-zoom button:hover {
    opacity: 0.6;
    color: var(--color-text);
  }
  .look-zoom button[aria-pressed='true'] {
    color: var(--fg, var(--color-text));
  }
</style>
