---
import { getCollection } from 'astro:content';
import type { GetStaticPaths } from 'astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { POSTS_PER_PAGE, SITE_DESCRIPTION } from '../consts';

// Paginated, reverse-chronological home feed.
// Page 1 is `/`, then `/2`, `/3`, … — explicit pagination, no infinite scroll.
export const getStaticPaths = (async ({ paginate }) => {
  const posts = (await getCollection('posts')).sort(
    (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
  );
  return paginate(posts, { pageSize: POSTS_PER_PAGE });
}) satisfies GetStaticPaths;

const { page } = Astro.props;
---

<BaseLayout description={SITE_DESCRIPTION}>
  <main>
    {page.data.map((post) => <PostCard post={post} />)}

    <nav class="pagination">
      {page.url.prev ? <a href={page.url.prev}>← Newer</a> : <span class="spacer"></span>}
      <span>Page {page.currentPage} of {page.lastPage}</span>
      {page.url.next ? <a href={page.url.next}>Older →</a> : <span class="spacer"></span>}
    </nav>
  </main>
</BaseLayout>
